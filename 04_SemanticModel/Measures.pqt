		measure 'School Head Compression Ratio' =
				
				VAR TopSalary =
				    CALCULATE(
				        AVERAGE(Fact_Salary[Measure_Salary_EUR]),
				        Dim_Role[Role] = "School Head",
				        REMOVEFILTERS(Dim_Salary_Stage),
				        Dim_Salary_Stage[Salary_Stage] = "Maximum"
				    )
				VAR StartSalary =
				    CALCULATE(
				        AVERAGE(Fact_Salary[Measure_Salary_EUR]),
				        Dim_Role[Role] = "School Head",
				        REMOVEFILTERS(Dim_Salary_Stage),
				        Dim_Salary_Stage[Salary_Stage] = "Minimum"
				    )
				RETURN
				DIVIDE(TopSalary, StartSalary)
			formatString: #,0.00
			lineageTag: bc495246-fc50-475e-8a31-217730c8c47e

