		measure 'Highest Paying Country Label' = ```
				
				VAR CountriesWithSalary =
				    FILTER(
				        ALL(Dim_Country),
				        NOT ISBLANK([Salary (PPS)]) && [Salary (PPS)] > 0
				    )
				VAR TopCountry =
				    TOPN(
				        1,
				        CountriesWithSalary,
				        [Salary (PPS)],
				        DESC
				    )
				VAR CountryName =
				    MAXX(TopCountry, Dim_Country[Country_Name_Clean])
				VAR SalaryValue =
				    MAXX(TopCountry, [Salary (PPS)])
				RETURN
				CountryName
				
				```
			lineageTag: 8bd258dd-70e7-4887-abcd-8de3465d6376

			changedProperty = IsHidden

