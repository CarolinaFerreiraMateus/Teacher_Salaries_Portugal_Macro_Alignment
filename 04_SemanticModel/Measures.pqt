		measure 'Ranking PT Position' =
				
				VAR CountriesWithData =
				    FILTER(
				        ALL(Dim_Country),
				        NOT ISBLANK([Salary (PPS)]) &&
				        [Salary (PPS)] > 0
				    )
				
				VAR RankPT =
				    CALCULATE(
				        RANKX(
				            CountriesWithData,
				            [Salary (PPS)],
				            ,
				            DESC,
				            DENSE
				        ),
				        Dim_Country[Country_Code] = "PT"
				    )
				
				VAR LastTwoDigits = MOD(RankPT, 100)
				VAR LastDigit = MOD(RankPT, 10)
				
				VAR Suffix =
				    SWITCH(
				        TRUE(),
				        LastTwoDigits IN {11, 12, 13}, "th",
				        LastDigit = 1, "st",
				        LastDigit = 2, "nd",
				        LastDigit = 3, "rd",
				        "th"
				    )
				
				RETURN
				RankPT & Suffix
			lineageTag: 3d0fe810-c671-46cd-9000-8493e1cc2ed7

			changedProperty = IsHidden

		measure 'Salary Highest Paying Country (PPS)' =
				
